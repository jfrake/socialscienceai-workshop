{
  "name": "Social Science AI workshop",
  "image": "mcr.microsoft.com/devcontainers/universal:2-linux",
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "REditorSupport.r"
      ]
    }
  },
  "remoteUser": "codespace",
  "hostRequirements": {
    "cpus": 2,
    "memory": "4gb",
    "storage": "32gb"
  }
}
